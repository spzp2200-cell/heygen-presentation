  <!-- GSAP および 制御ロジックの構築 -->
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
  <script>
    const tl = gsap.timeline({ paused: true });

    // ==================== 1. GSAPタイムラインのアニメーション定義 ====================

    // --- 【共通初期化設定】 (0.0s) ---
    tl.set("#scene-intro", { autoAlpha: 1, display: "block", pointerEvents: "auto" }, 0);
    tl.set("#scene-a, #scene-b", { autoAlpha: 0, display: "none", pointerEvents: "none" }, 0);
    tl.set("#intro-choices", { autoAlpha: 0, pointerEvents: "none" }, 0);

    // --- 【イントロアニメーション】 (0.0s - 10.0s) ---
    tl.to("#wrapper-intro", { opacity: 1, y: 0, duration: 1.2, ease: "power3.out" }, 0.2);
    tl.from("#intro-title", { opacity: 0, y: -30, duration: 1.0, ease: "power3.out" }, 0.5);
    tl.from("#intro-desc", { opacity: 0, y: 20, duration: 0.8, ease: "power3.out" }, 1.0);
    tl.fromTo("#glow-1", { scale: 0.9, opacity: 0.6 }, { scale: 1.15, opacity: 1.0, duration: 5.0, repeat: 3, yoyo: true, ease: "sine.inOut" }, 0);
    
    // 選択ボタンがスムーズにフェードイン
    tl.to("#intro-choices", { autoAlpha: 1, pointerEvents: "auto", duration: 0.6, ease: "power2.out" }, 9.4);
    
    // 【10.0秒時点】：一時停止
    tl.addPause(10.0, () => { stopAllMedia(); });

    // --- 【シーンA（アバター5）】 (11.0s - 18.0s) ---
    tl.set("#scene-intro, #scene-b", { autoAlpha: 0, display: "none", pointerEvents: "none" }, 11.0);
    tl.set("#scene-a", { display: "block", pointerEvents: "auto" }, 11.0);
    tl.to("#scene-a", { autoAlpha: 1, duration: 0.6 }, 11.0);
    tl.to("#wrapper-a", { opacity: 1, duration: 0.8 }, 11.2);
    tl.from("#title-a", { opacity: 0, y: -20, duration: 0.8, ease: "power2.out" }, 11.5);
    tl.from("#desc-a", { opacity: 0, y: 15, duration: 0.8, ease: "power2.out" }, 11.9);
    tl.from("#btn-back-a", { opacity: 0, scale: 0.95, duration: 0.6 }, 12.3);

    // 【18.0秒時点】：一時停止
    tl.addPause(18.0, () => { stopAllMedia(); });

    // --- 【シーンB（HyperFrames）】 (19.0s - 26.0s) ---
    tl.set("#scene-intro, #scene-a", { autoAlpha: 0, display: "none", pointerEvents: "none" }, 19.0);
    tl.set("#scene-b", { display: "block", pointerEvents: "auto" }, 19.0);
    tl.to("#scene-b", { autoAlpha: 1, duration: 0.6 }, 19.0);
    tl.to("#wrapper-b", { opacity: 1, duration: 0.8 }, 19.2);
    tl.from("#title-b", { opacity: 0, x: -30, duration: 0.8, ease: "power3.out" }, 19.5);
    tl.from("#desc-b", { opacity: 0, y: 15, duration: 0.8, ease: "power2.out" }, 19.9);
    tl.from("#btn-back-b", { opacity: 0, scale: 0.95, duration: 0.6 }, 20.3);

    // 【26.0秒時点】：一時停止
    tl.addPause(26.0, () => { stopAllMedia(); });

    tl.set({}, {}, 30.0);

    // レンダラーへの登録
    window.__timelines = window.__timelines || {};
    window.__timelines["hiraoka-presentation"] = tl;

    // ==================== 2. ナビゲーションおよび音声・映像の制御ロジック ====================

    // 各種メディア要素の取得
    const bgm = document.getElementById("bgm-track");
    const voiceIntro = document.getElementById("voice-intro");
    const voiceA = document.getElementById("voice-a");
    const voiceB = document.getElementById("voice-b");

    const videoIntro = document.getElementById("video-intro");
    const videoA = document.getElementById("video-a");
    const videoB = document.getElementById("video-b");

    // 全ての音声とビデオを一括停止・初期化する関数
    function stopAllMedia() {
      [voiceIntro, voiceA, voiceB].forEach(audio => {
        audio.pause();
        audio.currentTime = 0;
      });
      [videoIntro, videoA, videoB].forEach(video => {
        video.pause();
        video.currentTime = 0;
      });
    }

    // ナビゲーションジャンプと音声・映像の完全同期制御
    function navigateTo(targetTime, activeVoice, activeVideo) {
      stopAllMedia();
      
      if (bgm.paused) {
        bgm.play().catch(e => console.log("BGM play error:", e));
      }

      // GSAPタイムラインをジャンプ
      tl.play(targetTime);

      // 対象音声の同期再生
      if (activeVoice) {
        activeVoice.currentTime = 0;
        activeVoice.play().catch(e => console.log("Voice autoplay blocked:", e));
      }

      // 対象ビデオの同期再生
      if (activeVideo) {
        activeVideo.currentTime = 0;
        activeVideo.play().catch(e => console.log("Video autoplay blocked:", e));
      }
    }

    // --- ボタンイベントのバインド ---

    // 選択A：アバター5への分岐 (11.0秒から)
    document.getElementById("btn-choice-a").addEventListener("click", (e) => {
      e.stopPropagation();
      navigateTo(11.0, voiceA, videoA);
    });

    // 選択B：HyperFramesへの分岐 (19.0秒から)
    document.getElementById("btn-choice-b").addEventListener("click", (e) => {
      e.stopPropagation();
      navigateTo(19.0, voiceB, videoB);
    });

    // メニューに戻る
    document.querySelectorAll(".nav-back-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        stopAllMedia();
        tl.seek(10.0); // 選択画面（一時停止中の10秒目）に戻る
      });
    });

    // 初回のロードおよび再生開始処理
    let isStarted = false;
    window.addEventListener("click", (e) => {
      // ボタン自体のクリック時はこのリスナーの自動再生処理をスキップ
      if (e.target.closest("button") || e.target.closest(".choice-btn") || e.target.closest(".nav-back-btn")) {
        return;
      }
      
      if (!isStarted && tl.time() === 0) {
        isStarted = true;
        navigateTo(0.0, voiceIntro, videoIntro);
      }
    });
  </script>
</body>
