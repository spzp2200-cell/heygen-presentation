<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HeyGen & HyperFrames Interactive Presentation</title>
  <!-- Google Fonts プレミアムタイポグラフィ -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800;900&display=swap" rel="stylesheet">
  
  <style>
    /* リセットと基本レイアウト設定 */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    body {
      background-color: #030108;
      color: #ffffff;
      font-family: 'Inter', sans-serif;
      overflow: hidden;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      width: 100vw;
    }

    /* 16:9 巨大ステージコンテナ */
    #root {
      position: relative;
      width: 1920px;
      height: 1080px;
      background: radial-gradient(circle at 30% 30%, #160a2b 0%, #030108 100%);
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    /* 背景の発光装飾（有限アニメーション用） */
    .bg-glow-effect {
      position: absolute;
      width: 800px;
      height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(138, 43, 226, 0.12) 0%, transparent 75%);
      filter: blur(80px);
      pointer-events: none;
      z-index: 1;
    }

    /* 左側のスライドパネルエリア（60%幅） */
    .slide-panel {
      position: absolute;
      left: 80px;
      top: 90px;
      width: 1100px;
      height: 900px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      z-index: 10;
    }

    /* プレミアムスライドカード */
    .slide-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 60px 80px;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      backdrop-filter: blur(20px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    /* 右側のアバター配置エリア（40%幅） */
    .avatar-area {
      position: absolute;
      right: 80px;
      bottom: 0;
      width: 600px;
      height: 960px;
      z-index: 15;
      display: flex;
      justify-content: center;
      align-items: flex-end;
    }

    /* アバター映像のラッパー（バグ回避のために video に直にアニメーションをかけない） */
    .avatar-wrapper {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
      border-radius: 24px;
    }

    .avatar-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* 仮のアバタープレースホルダー用UI */
    .avatar-placeholder {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%);
      border: 2px dashed rgba(255, 255, 255, 0.15);
      border-radius: 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      color: rgba(255, 255, 255, 0.4);
      font-size: 20px;
    }

    /* テキストスタイル */
    h1, h2, h3 {
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      letter-spacing: -1px;
    }

    .gradient-text-purple {
      background: linear-gradient(135deg, #e3a9ff 0%, #9e5bfb 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .gradient-text-cyan {
      background: linear-gradient(135deg, #a0f9ff 0%, #00f0ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* インタラクティブボタンの定義 */
    .btn-container {
      display: flex;
      gap: 30px;
      margin-top: 50px;
    }

    .choice-btn {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      padding: 24px 44px;
      font-size: 24px;
      color: white;
      border-radius: 18px;
      border: 2px solid transparent;
      cursor: pointer;
      transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    }

    /* ボタン①：アバター5用 */
    #btn-choice-a {
      background: linear-gradient(135deg, rgba(0, 240, 255, 0.15) 0%, rgba(0, 128, 128, 0.1) 100%);
      border-color: rgba(0, 240, 255, 0.4);
      box-shadow: 0 0 20px rgba(0, 240, 255, 0.1);
    }
    #btn-choice-a:hover {
      background: linear-gradient(135deg, rgba(0, 240, 255, 0.3) 0%, rgba(0, 128, 128, 0.2) 100%);
      border-color: #00f0ff;
      box-shadow: 0 0 35px rgba(0, 240, 255, 0.4);
      transform: translateY(-4px);
    }

    /* ボタン②：HyperFrames用 */
    #btn-choice-b {
      background: linear-gradient(135deg, rgba(138, 43, 226, 0.2) 0%, rgba(75, 0, 130, 0.15) 100%);
      border-color: rgba(138, 43, 226, 0.4);
      box-shadow: 0 0 20px rgba(138, 43, 226, 0.1);
    }
    #btn-choice-b:hover {
      background: linear-gradient(135deg, rgba(138, 43, 226, 0.35) 0%, rgba(75, 0, 130, 0.2) 100%);
      border-color: #8a2be2;
      box-shadow: 0 0 35px rgba(138, 43, 226, 0.4);
      transform: translateY(-4px);
    }

    /* メニューに戻るナビゲーションボタン */
    .nav-back-btn {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      margin-top: 40px;
      padding: 14px 28px;
      font-size: 18px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: rgba(255, 255, 255, 0.03);
      color: #bbb;
      border-radius: 30px;
      cursor: pointer;
      width: fit-content;
      transition: all 0.3s ease;
    }

    .nav-back-btn:hover {
      background: rgba(255, 255, 255, 0.12);
      color: white;
      border-color: white;
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.1);
    }

    /* シーン基本構造 (表示とポインターイベントの厳密な制御) */
    .scene-container {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      display: none;
      pointer-events: none;
    }
  </style>
</head>
<body>

  <div data-hf-id="hf-8q40" id="root" data-composition-id="hiraoka-presentation" data-width="1920" data-height="1080" data-duration="30" data-start="0">
    
