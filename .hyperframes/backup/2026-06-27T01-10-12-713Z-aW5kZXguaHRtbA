      <!-- アバター表示エリア -->
      <div data-hf-id="hf-ep8n" class="avatar-area">
        <div data-hf-id="hf-heja" id="wrapper-intro" class="avatar-wrapper" style="opacity: 0; transform: translateY(40px);">
          <!-- 本番アセット用ビデオ要素 -->
          <video data-hf-id="hf-trrw" id="video-intro" class="avatar-video" src="assets/avatar_intro.webm" data-start="0.2" muted playsinline></video>
        </div>
      </div>

    </div>

    <!-- ==================== 2. 【シーンA】アバター5解説ルート (11.0s - 18.0s) ==================== -->
    <div data-hf-id="hf-vmor" id="scene-a" class="clip scene-container" data-start="11" data-duration="7">
      
      <div data-hf-id="hf-z10u" class="slide-panel">
        <div data-hf-id="hf-ckdy" class="slide-card">
          <div data-hf-id="hf-dhui" style="text-transform: uppercase; font-size: 16px; font-weight: 600; color: #00f0ff; letter-spacing: 3px; margin-bottom: 20px;">Chapter 1: Avatar 5</div>
          <h2 data-hf-id="hf-ezxe" id="title-a" style="font-size: 56px; font-weight: 900; margin-bottom: 30px;">
            自分そっくりの写真を<br data-hf-id="hf-szow"><span data-hf-id="hf-xzud" class="gradient-text-cyan">楽しく動かしてみましょう！</span>
          </h2>
          <p data-hf-id="hf-kurb" id="desc-a" style="font-size: 24px; color: #9bb8be; line-height: 1.7; max-width: 900px;">
            アバター5を使うと、お気に入りのポートレートや静止画をベースに、まるで本当に喋っているかのような高精細で感情豊かなリップシンク動画を瞬時に作成できます。
          </p>
          <button data-hf-id="hf-og2c" id="btn-back-a" class="nav-back-btn">← メニューへ戻る</button>
