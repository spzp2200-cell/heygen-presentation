          <video data-hf-id="hf-e9w8" id="video-a" class="avatar-video" src="assets/avatar_a.webm" muted playsinline></video>
        </div>
      </div>

    </div>

    <!-- ==================== 3. 【シーンB】HyperFrames解説ルート (19.0s - 26.0s) ==================== -->
    <div data-hf-id="hf-menc" id="scene-b" class="clip scene-container" data-start="19" data-duration="7">
      
      <div data-hf-id="hf-zfbv" class="slide-panel">
        <div data-hf-id="hf-cyoz" class="slide-card">
          <div data-hf-id="hf-nikw" style="text-transform: uppercase; font-size: 16px; font-weight: 600; color: #9e5bfb; letter-spacing: 3px; margin-bottom: 20px;">Chapter 2: HyperFrames</div>
          <h2 data-hf-id="hf-ziqx" id="title-b" style="font-size: 56px; font-weight: 900; margin-bottom: 30px;">
            AI Agentを使って<br data-hf-id="hf-sldv"><span data-hf-id="hf-ig5d" class="gradient-text-purple">簡単に動画を作ってみましょう！</span>
