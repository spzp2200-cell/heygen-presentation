    <audio data-hf-id="hf-5tks" id="voice-b" src="assets/narration_b.mp3" data-volume="1.0"></audio>

    <!-- 背景装飾用の光球 -->
    <div data-hf-id="hf-xju8" id="glow-1" class="bg-glow-effect" style="left: -100px; top: -100px;"></div>
    <div data-hf-id="hf-4exh" id="glow-2" class="bg-glow-effect" style="right: -100px; bottom: -100px; background: radial-gradient(circle, rgba(0, 240, 255, 0.08) 0%, transparent 75%);"></div>

    <!-- ==================== 1. 【シーン1】イントロ・問いかけ (0.0s - 10.0s) ==================== -->
    <div data-hf-id="hf-883c" id="scene-intro" class="clip scene-container" data-start="0" data-duration="10">
      
      <!-- スライドパネル -->
      <div data-hf-id="hf-9s8a" class="slide-panel">
        <div data-hf-id="hf-fzw2" class="slide-card">
          <div data-hf-id="hf-6v0n" style="text-transform: uppercase; font-size: 16px; font-weight: 600; color: #9e5bfb; letter-spacing: 3px; margin-bottom: 20px;">HeyGen Ambassador Present</div>
          <h1 data-hf-id="hf-3ckv" id="intro-title" style="font-size: 64px; font-weight: 900; line-height: 1.2; margin-bottom: 30px;">
            みなさん、こんにちは！<br data-hf-id="hf-x5px">
